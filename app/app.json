{
  "expo": {
    "name": "ALUPRO",
    "slug": "alupro",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#090c0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.scaiorodrigues.alupro"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#090c0f"
      },
      "package": "com.scaiorodrigues.alupro",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        { "photosPermission": "Permitir acesso para upload de desenhos de perfis." }
      ]
    ],
    "scheme": "alupro",
    "experiments": { "typedRoutes": true }
  }
}
