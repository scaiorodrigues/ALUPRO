# ── Supabase ─────────────────────────────────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── App ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=production

# ── Admin demo (só para desenvolvimento local) ─────────────────────────
# Não use em produção — configure o usuário admin pelo Supabase Auth
EXPO_PUBLIC_DEMO_MODE=false
