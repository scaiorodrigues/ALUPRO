# Anthropic — Vision AI para extração de dimensões
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — banco de dados e storage
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-anon-key
SUPABASE_BUCKET=profile-drawings

# Pipeline — configurações opcionais
MIN_CONFIDENCE=0.65        # Score mínimo para aceitar resultado automático
SNAP_ANGLE_TOLERANCE=5.0   # Graus de tolerância para snap de ângulos
DXF_SCALE=1.0              # Escala do DXF gerado (1.0 = milímetros reais)
